rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // TEMPORARY: Allow all authenticated users to read/write everything for debugging
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (request.auth.token.email == "tyler.ortolano95@gmail.com" && request.auth.token.email_verified == true);
    }

    // Jobs collection
    match /jobs/{jobId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // LinkedIn posts collection
    match /linkedinPosts/{postId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // Users collection (for roles)
    match /users/{userId} {
      allow read: if isAuthenticated() && request.auth.uid == userId;
      allow write: if isAdmin();
    }
  }
}
