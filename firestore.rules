rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: jobs
    // Document ID: auto-generated
    // Fields:
    //   - ref: string (required)
    //   - title: string (required)
    //   - location: string (required)
    //   - type: string (required)
    //   - salary: string (required)
    //   - summary: string (required)
    //   - responsibilities: list (required)
    //   - requirements: list (required)
    //   - createdAt: timestamp (optional)
    //   - updatedAt: timestamp (optional)
    //
    // Collection: linkedinPosts
    // Document ID: auto-generated
    // Fields:
    //   - author: string (required)
    //   - role: string (required)
    //   - content: string (required)
    //   - date: string (required)
    //   - avatar: string (required)
    //   - image: string (optional)
    //   - createdAt: timestamp (optional)
    //   - updatedAt: timestamp (optional)
    //
    // ===============================================================

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "tyler.ortolano95@gmail.com" && request.auth.token.email_verified == true));
    }

    // Jobs collection
    match /jobs/{jobId} {
      // Publicly readable
      allow read: if true;
      // Only admins can write (via Firebase Auth if used, but backend uses firebase-admin)
      allow write: if isAdmin();
    }

    // LinkedIn posts collection
    match /linkedinPosts/{postId} {
      // Publicly readable
      allow read: if true;
      // Only admins can write
      allow write: if isAdmin();
    }

    // Users collection (for roles)
    match /users/{userId} {
      allow read: if isAuthenticated() && request.auth.uid == userId;
      allow write: if isAdmin();
    }
  }
}
