{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/render.ts": { "includeFiles": "data/jobs.json" },
    "api/sitemap.ts": { "includeFiles": "data/jobs.json" }
  },
  "redirects": [
    {
      "source": "/",
      "has": [{ "type": "host", "value": "www.thecertusgroup.tech" }],
      "destination": "https://thecertusgroup.tech/",
      "permanent": true
    },
    {
      "source": "/:path+",
      "has": [{ "type": "host", "value": "www.thecertusgroup.tech" }],
      "destination": "https://thecertusgroup.tech/:path+",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/sitemap.xml", "destination": "/api/sitemap" },
    { "source": "/employers", "destination": "/api/render?page=employers" },
    { "source": "/jobs", "destination": "/api/render" },
    { "source": "/jobs/:id", "destination": "/api/render?id=:id" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
